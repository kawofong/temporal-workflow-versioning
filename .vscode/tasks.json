{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "temporal-server",
            "type": "shell",
            "command": "temporal server start-dev",
            "isBackground": true,
            "problemMatcher": [
                {
                    "pattern": [
                        {
                            "regexp": "^(NOMATCH)(.*)$",
                            "file": 1,
                            "message": 2,
                            "kind": "file"
                        }
                    ],
                    "background": {
                        "activeOnStart": true,
                        "beginsPattern": "Temporal CLI",
                        "endsPattern": "Temporal Server:"
                    }
                }
            ],
            "presentation": {
                "group": "server",
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "worker-v1",
            "type": "shell",
            "command": "source ~/.zshrc || mise run worker",
            "isBackground": true,
            "dependsOn": ["temporal-server"],
            "problemMatcher": [
                {
                    "pattern": [
                        {
                            "regexp": "^(NOMATCH)(.*)$",
                            "file": 1,
                            "message": 2,
                            "kind": "file"
                        }
                    ],
                    "background": {
                        "activeOnStart": true,
                        "beginsPattern": "worker:v1",
                        "endsPattern": "Worker started"
                    }
                }
            ],
            "presentation": {
                "group": "workers",
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "worker2",
            "type": "shell",
            "command": "echo 'Command to run: BUILD_ID=v2.0 uv run worker.py'; ${env:SHELL}",
            "options": {
                "cwd": "${workspaceFolder}/python"
            },
            "isBackground": true,
            "problemMatcher": [],
            "presentation": {
                "group": "workers",
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "start-simulation",
            "type": "shell",
            "command": "source ~/.zshrc || mise run simulation",
            "isBackground": true,
            "dependsOn": ["worker-v1"],
            "problemMatcher": [],
            "presentation": {
                "group": "starters",
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "set-current-version-v1",
            "type": "shell",
            "command": "source ~/.zshrc || mise run set-current-version v1.0",
            "isBackground": true,
            "dependsOn": ["worker-v1"],
            "problemMatcher": [],
            "presentation": {
                "group": "starters",
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "Start Simulation V1",
            "dependsOn": ["temporal-server", "worker-v1", "start-simulation", "set-current-version-v1"],
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}

